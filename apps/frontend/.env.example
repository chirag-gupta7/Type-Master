# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000

# Internal API Secret for server-side NextAuth -> backend token exchange.
# Keep server-only (do NOT prefix with NEXT_PUBLIC_) and match backend value.
INTERNAL_API_SECRET=your-internal-api-secret-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-generated-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Database Connection (shared with backend Prisma models)
DATABASE_URL=postgresql://user:password@localhost:5432/typemaster
